# Synapse ke API keys - is file ko copy karke ".env" banao aur keys bharo.
# .env git mein commit nahi hoti (gitignore mein hai).

# Serper.dev - Google search (funding/hiring/news). Free tier: 2,500 search.
# https://serper.dev  -> signup -> API key
SERPER_API_KEY=

# Google Gemini - brief + email likhta hai. Flash model sabse sasta + free tier.
# https://aistudio.google.com/apikey -> Create API key (FREE)
GEMINI_API_KEY=

# Optional: model override. Sasta -> mehenga:
#   gemini-2.0-flash-lite  (sabse sasta)
#   gemini-2.0-flash       (default, balanced)
#   gemini-2.5-flash       (behtar quality)
# SYNAPSE_GEMINI_MODEL=gemini-2.0-flash
